# Endereço da API do backend (TheusSales/8fsdt-tech-challenge-2).
# O prefixo EXPO_PUBLIC_ é obrigatório: sem ele a variável não chega ao bundle.
#
# O valor correto depende de onde o app roda:
#   simulador iOS       -> http://localhost:3000
#   emulador Android    -> http://10.0.2.2:3000
#   celular via Expo Go -> http://<IP-DA-SUA-MAQUINA-NA-LAN>:3000
EXPO_PUBLIC_API_URL=http://localhost:3000
